generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  viewer
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  passwordHash  String?   @map("password_hash")
  role          Role      @default(viewer)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  accounts      Account[]
  sessions      Session[]
  apiKeys       ApiKey[]
  dedupDecisions DedupCandidate[] @relation("DedupDecidedBy")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#6366f1")
  createdAt DateTime @default(now()) @map("created_at")
  feeds     Feed[]

  @@map("categories")
}

model Feed {
  id            String    @id @default(cuid())
  title         String
  url           String    @unique
  siteUrl       String?   @map("site_url")
  description   String?
  categoryId    String?   @map("category_id")
  category      Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  isActive      Boolean   @default(true) @map("is_active")
  syncInterval  Int       @default(30) @map("sync_interval")
  lastSyncAt    DateTime? @map("last_sync_at")
  lastSyncError String?   @map("last_sync_error")
  articleCount  Int       @default(0) @map("article_count")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  articles      Article[]
  syncLogs      SyncLog[]

  @@map("feeds")
}

model Article {
  id           String        @id @default(cuid())
  feedId       String        @map("feed_id")
  feed         Feed          @relation(fields: [feedId], references: [id], onDelete: Cascade)
  title        String
  url          String        @unique
  author       String?
  content      String?
  summary      String?
  imageUrl     String?       @map("image_url")
  publishedAt  DateTime?     @map("published_at")
  isRead       Boolean       @default(false) @map("is_read")
  isBookmarked Boolean       @default(false) @map("is_bookmarked")
  guid         String?
  createdAt    DateTime      @default(now()) @map("created_at")
  fundingRound           FundingRound?
  fundEvent              FundEvent?
  companyValueIndicators CompanyValueIndicator[]

  @@index([feedId, publishedAt(sort: Desc)])
  @@index([isBookmarked])
  @@index([publishedAt(sort: Desc)])
  @@map("articles")
}

model FundingRound {
  id          String   @id @default(cuid())
  articleId   String   @unique @map("article_id")
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  companyName String   @map("company_name")
  amount      Float?
  currency    String   @default("USD")
  amountUsd   Float?   @map("amount_usd")
  stage       String?
  investors   String[]
  leadInvestor String? @map("lead_investor")
  country     String?
  confidence  Float    @default(0)
  rawExcerpt  String?  @map("raw_excerpt")
  ingestedAt  DateTime? @map("ingested_at")
  dismissedAt DateTime? @map("dismissed_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([stage])
  @@index([country])
  @@index([createdAt(sort: Desc)])
  @@map("funding_rounds")
}

model FundEvent {
  id         String   @id @default(cuid())
  articleId  String   @unique @map("article_id")
  article    Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  fundName   String   @map("fund_name")
  firmName   String   @map("firm_name")
  amount     Float?
  currency   String   @default("USD")
  amountUsd  Float?   @map("amount_usd")
  fundType   String?  @map("fund_type")
  vintage    String?
  country    String?
  confidence Float    @default(0)
  rawExcerpt String?   @map("raw_excerpt")
  ingestedAt  DateTime? @map("ingested_at")
  dismissedAt DateTime? @map("dismissed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([firmName])
  @@index([createdAt(sort: Desc)])
  @@map("fund_events")
}

model CompanyValueIndicator {
  id          String    @id @default(cuid())
  articleId   String    @map("article_id")
  article     Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  companyName String    @map("company_name")
  metricType  String    @map("metric_type")
  value       Float?
  currency    String    @default("USD")
  valueUsd    Float?    @map("value_usd")
  unit        String?
  period      String?
  confidence  Float     @default(0)
  rawExcerpt  String?   @map("raw_excerpt")
  ingestedAt  DateTime? @map("ingested_at")
  dismissedAt DateTime? @map("dismissed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([companyName])
  @@index([metricType])
  @@index([createdAt(sort: Desc)])
  @@map("company_value_indicators")
}

model SyncLog {
  id            String   @id @default(cuid())
  feedId        String   @map("feed_id")
  feed          Feed     @relation(fields: [feedId], references: [id], onDelete: Cascade)
  status        String   // "success" | "error"
  articlesFound Int      @default(0) @map("articles_found")
  articlesNew   Int      @default(0) @map("articles_new")
  fundingFound  Int      @default(0) @map("funding_found")
  errorMessage  String?  @map("error_message")
  durationMs    Int      @default(0) @map("duration_ms")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([feedId, createdAt(sort: Desc)])
  @@map("sync_logs")
}

model AppSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String

  @@map("app_settings")
}

enum HistoricalUrlStatus {
  discovered
  scraped
  processed
  imported
  skipped
  error
}

model HistoricalUrl {
  id              String              @id @default(cuid())
  url             String              @unique
  source          String                                    // e.g. "EU-Startups"
  lastmod         DateTime?                                 // from sitemap
  matchedKeywords String[]            @map("matched_keywords")
  status          HistoricalUrlStatus @default(discovered)
  errorMessage    String?             @map("error_message")
  title           String?                                   // after scraping
  content         String?             @db.Text              // after scraping
  articleId       String?             @unique @map("article_id") // after import
  crawlBatch      String?             @map("crawl_batch")   // groups crawl runs
  scrapedAt       DateTime?           @map("scraped_at")
  processedAt     DateTime?           @map("processed_at")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  @@index([status])
  @@index([source])
  @@index([crawlBatch])
  @@index([createdAt(sort: Desc)])
  @@map("historical_urls")
}

model ApiKey {
  id           String    @id @default(cuid())
  name         String                              // Label, e.g. "inventure-2.0 production"
  prefix       String                              // First 8 chars of key for display (e.g. "orb_a3f2...")
  hashedKey    String    @unique @map("hashed_key") // SHA-256 hash of the full key
  scopes       String[]  @default(["funding-rounds"]) // Which API endpoints this key can access
  rateLimit    Int       @default(100) @map("rate_limit") // Requests per hour
  isActive     Boolean   @default(true) @map("is_active")
  expiresAt    DateTime? @map("expires_at")
  lastUsedAt   DateTime? @map("last_used_at")
  requestCount Int       @default(0) @map("request_count")
  createdById  String    @map("created_by_id")
  createdBy    User      @relation(fields: [createdById], references: [id])
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  usageLogs    ApiKeyUsageLog[]

  @@index([hashedKey])
  @@index([isActive])
  @@map("api_keys")
}

model ApiKeyUsageLog {
  id        String   @id @default(cuid())
  apiKeyId  String   @map("api_key_id")
  apiKey    ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  endpoint  String
  method    String
  status    Int
  ip        String?
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([apiKeyId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("api_key_usage_logs")
}

model Post {
  id              String   @id @default(cuid())
  fundingRoundKey String   @unique @map("funding_round_key")
  companyName     String   @map("company_name")
  amountEur       Float?   @map("amount_eur")
  stage           String?
  content         String
  publishedAt     DateTime? @map("published_at")
  publishError    String?   @map("publish_error")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([companyName])
  @@index([createdAt(sort: Desc)])
  @@map("posts")
}

enum DedupEntityType {
  company
  investor
  round
}

enum DedupStatus {
  pending
  confirmed
  rejected
  skipped
}

model DedupCandidate {
  id          String          @id @default(cuid())
  entityType  DedupEntityType @map("entity_type")
  leftKey     String          @map("left_key")
  rightKey    String          @map("right_key")
  tier        Int
  score       Float
  reasons     Json
  leftSnapshot  Json?         @map("left_snapshot")
  rightSnapshot Json?         @map("right_snapshot")
  status      DedupStatus     @default(pending)
  winnerKey     String?       @map("winner_key")
  mergeSnapshot Json?         @map("merge_snapshot")
  decidedById String?         @map("decided_by_id")
  decidedBy   User?           @relation("DedupDecidedBy", fields: [decidedById], references: [id], onDelete: SetNull)
  decidedAt   DateTime?       @map("decided_at")
  note        String?
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  @@unique([entityType, leftKey, rightKey])
  @@index([entityType, status])
  @@index([status, createdAt(sort: Desc)])
  @@map("dedup_candidates")
}

model DedupRun {
  id              String   @id @default(cuid())
  startedAt       DateTime @default(now()) @map("started_at")
  finishedAt      DateTime? @map("finished_at")
  status          String   @default("running")
  companiesScanned Int     @default(0) @map("companies_scanned")
  investorsScanned Int     @default(0) @map("investors_scanned")
  roundsScanned    Int     @default(0) @map("rounds_scanned")
  candidatesNew    Int     @default(0) @map("candidates_new")
  candidatesUpdated Int    @default(0) @map("candidates_updated")
  durationMs       Int     @default(0) @map("duration_ms")
  errorMessage     String? @map("error_message")
  triggeredBy      String  @default("cron") @map("triggered_by")

  @@index([startedAt(sort: Desc)])
  @@map("dedup_runs")
}
